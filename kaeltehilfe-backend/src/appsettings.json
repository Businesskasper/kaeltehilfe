{
	"Logging": {
		"LogLevel": {
			"Default": "Information",
			"Microsoft.AspNetCore": "Warning"
		}
	},
	"AllowedHosts": "*",
	"ConnectionStrings": {
		"SqliteDb": "Data Source=/opt/kaeltehilfe-api/db/kaeltehilfeDatabase.db"
	},
	"Authorization": {
		"Audience": "account",
		"Client": "users",
		"MachineClient": "backend",
		"MachineClientSecretVar": "KC_CLIENT_SECRET"
	},
	"CertificateSettings": {
		"RootCertPath": "/opt/kaeltehilfe-api/cert/root/rootCa.pfx",
		"RootCertPasswordVar": "ROOT_CERT_PASSWORD",
		"ClientCertDir": "/opt/kaeltehilfe-api/cert/client",
		"CrlPath": "/opt/kaeltehilfe-api/cert/crl/crl.pem"
	}
}
